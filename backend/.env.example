# Copy this to .env and fill in real values — never commit .env to git

MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/jwt-abuse
JWT_SECRET=<minimum-32-character-secret-key-change-this>
JWT_EXPIRES_IN=60m
PORT=5000

# Optional: override default 12-hour token max age for lifetime abuse detection
# TOKEN_MAX_AGE_MS=43200000
